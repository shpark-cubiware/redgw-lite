# =============================================================================
# RedGW environment variables (.env)
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# WARNING: never commit the .env file to Git.
# =============================================================================

# ─── Image version ───────────────────────────────────────────
# Used for the redgw image tag (redgw:${REDGW_VERSION}) in docker-compose.yml.
# The single source of truth is the version in resource/pyproject.toml — build.sh
# builds the image with that value, so keep this in sync with pyproject
# (a mismatch makes compose look for an old tag).
REDGW_VERSION=0.1.2

# ─── Redis ───────────────────────────────────────────────────
# How to generate (32+ chars recommended):
#   openssl rand -base64 32
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=CHANGE_ME_use_strong_random_password

# ─── API Keys ───────────────────────────────────────────────
# Key format: redgw_ak_{clientID}_{random 32 chars}
#   - redgw_  : project prefix (distinguishes from other services' keys)
#   - ak_     : API key marker
#   - {ID}_   : client identifier (so a leaked key is immediately attributable)
#   - {random}: cryptographic random
#
# How to generate:
#   echo "redgw_ak_{ID}_$(openssl rand -hex 16)"
#
# Notes:
#   - Always generate a unique key per client
#   - When rotating a key, deliver the new key to the client over a secure channel
# ── Required: fixed clients ───────────────────────────────────
# MONITOR — read-only across all namespaces (monitoring system)
# admin   — read+write across all namespaces (operations/administration)
REDGW_CLIENT_MONITOR_API_KEY=redgw_ak_monitor_CHANGE_ME
REDGW_ADMIN_API_KEY=redgw_admin_CHANGE_ME

# ── Required: system clients (one or more) ────────────────────
# External systems that exchange data through RedGW.
# Format: REDGW_CLIENT_{NAME}_API_KEY (NAME: uppercase alphanumeric, 2-8 chars)
# Adding/removing a variable in this section is picked up automatically.
# NOTE: variables added here must also be declared in docker-compose.yml's environment.
REDGW_CLIENT_HRM_API_KEY=redgw_ak_hrm_CHANGE_ME
REDGW_CLIENT_ERP_API_KEY=redgw_ak_erp_CHANGE_ME
REDGW_CLIENT_CRM_API_KEY=redgw_ak_crm_CHANGE_ME

# ── Additional client examples (uncomment to add) ─────────────
# REDGW_CLIENT_WMS_API_KEY=redgw_ak_wms_CHANGE_ME
# REDGW_CLIENT_FMS_API_KEY=redgw_ak_fms_CHANGE_ME



# ─── CORS allowed origins (comma-separated) ──────────────────
# If empty, the cors_origins value from config.yaml is used.
# REDGW_CORS_ORIGINS=https://app1.example.com,https://app2.example.com

# ─── Grafana (monitoring dashboard) ──────────────────────────
# Grafana admin password (default: admin)
# Change it immediately after the first login.
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password



# ─── TLS certificate (Nginx) ─────────────────────────────────
# Generate a self-signed certificate:
#   mkdir -p nginx/certs
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout nginx/certs/server.key -out nginx/certs/server.crt \
#     -subj "/CN=redgw.internal"
